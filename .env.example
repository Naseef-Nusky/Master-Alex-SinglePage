# IMPORTANT: Leave VITE_CONTACT_API_URL empty in production.
# The site will use /api/contact on the same domain (wellness.masteralex.co.uk).
# Nginx must proxy /api/ to http://127.0.0.1:3001 — same setup as masteralex.co.uk.
# Do NOT use api.masteralex.co.uk unless that DNS record exists.
VITE_CONTACT_API_URL=

